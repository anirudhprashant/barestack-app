# Environment variables for production deployment
# Set NODE_ENV=production in Coolify environment
NODE_ENV=production

# Port for the preview server (Coolify will provide this)
PORT=3000

# Optional: If you want to override the default Vite base path
# VITE_BASE_PATH=/

# Supabase credentials are currently hardcoded in services/supabaseClient.ts
# For better security, consider moving them to environment variables:
# VITE_SUPABASE_URL=your_supabase_url
# VITE_SUPABASE_ANON_KEY=your_supabase_anon_key