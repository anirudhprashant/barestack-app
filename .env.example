# BareStack CRM Environment Configuration
# Copy this file to .env.local and customize for your environment

# PocketBase URL
# For local development: http://127.0.0.1:8092
# For production: https://api.barestack.org (or your PocketBase endpoint)
VITE_POCKETBASE_URL=http://127.0.0.1:8092

# Optional: Enable source maps in production (default: false)
# VITE_SOURCE_MAPS=false
