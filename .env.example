# Server configuration
PORT=4000
CORS_ORIGIN=http://localhost:3000

# Database URL (do not commit real credentials)
# Example for local Postgres:
# DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/postgres

# JWT secret (change in production)
JWT_SECRET=change-me

# Supabase (frontend) configuration for Vite
# Set these in .env.local with your project values
# VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Dev convenience (optional)
# VITE_DEV_EMAIL=dev@example.com
# VITE_DEV_PASSWORD=devpassword123

# Supabase (server) admin configuration for auto-confirmed dev sign-up
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
